# SMTP (Yandex)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=th5tr@yandex.ru
SMTP_PASS=your_app_password_here

# Email to receive contact form submissions
CONTACT_TO=th5tr@yandex.ru

# Local dev server port
PORT=3001

# Vercel: add the same SMTP_* and CONTACT_TO variables in Project Settings → Environment Variables.
# SMTP_PASS must be a Yandex app password (not your login password):
# https://id.yandex.ru/security/app-passwords
